# Environment
APP_ENV=development

# JWT Configuration
JWT_SECRET_KEY=change-me-to-a-long-random-secret-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite+aiosqlite:///db.sqlite3
ALLOW_SQLITE_IN_PRODUCTION=0
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Public backend URL used to build absolute links for files
API_BASE_URL=http://localhost:8000

# CORS - comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_ORIGIN_REGEX=
TRUSTED_HOSTS=localhost,127.0.0.1

# Initial admin bootstrap
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=

# Optional local upload directory (used when Cloudinary is not configured)
UPLOAD_DIR=uploads

# Optional Cloudinary storage for task photos
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=maintenance-app/tasks

# Editing lock for work notifications (seconds)
WORK_NOTIFICATION_LOCK_TTL_SECONDS=90
